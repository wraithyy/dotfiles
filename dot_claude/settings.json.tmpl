{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "mcp__time_time_get-current-time",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(npx eslint:*)"
    ]
  },
  "model": "claude-opus-4-6",
{{- if eq .chezmoi.os "darwin" }}
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/permission-notify.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/question-notify.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "hour=$(date +%H); if [ $hour -ge 7 ] && [ $hour -lt 23 ]; then osascript -e 'display notification \"Odpověď dokončena\" with title \"Claude Code\" sound name \"Glass\"'; fi",
            "timeout": 5
          }
        ]
      }
    ]
  },
{{- end }}
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
