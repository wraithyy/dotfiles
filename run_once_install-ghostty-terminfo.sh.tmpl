#!/bin/bash
# Install ghostty terminfo if not already present
# This fixes "missing or unsuitable terminal: xterm-ghostty" on machines without Ghostty

if ! infocmp xterm-ghostty &>/dev/null; then
  echo "Installing xterm-ghostty terminfo..."
  tempfile=$(mktemp)
  if curl -fsSL -o "$tempfile" https://raw.githubusercontent.com/ghostty-org/ghostty/main/src/terminfo/ghostty.terminfo 2>/dev/null; then
    tic -x "$tempfile" 2>/dev/null && echo "xterm-ghostty terminfo installed." || echo "Failed to compile terminfo."
  else
    echo "Could not download ghostty terminfo (no internet?). Skipping."
  fi
  rm -f "$tempfile"
else
  echo "xterm-ghostty terminfo already installed."
fi
