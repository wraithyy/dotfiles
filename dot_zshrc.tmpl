# Fallback pro terminály bez ghostty terminfo (např. Raspberry Pi)
if [[ "$TERM" == "xterm-ghostty" ]] && ! infocmp xterm-ghostty &>/dev/null 2>&1; then
  export TERM=xterm-256color
fi

# Rychlé zobrazení promptu (instant prompt)

typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Oh My Zsh nastavení
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"
DISABLE_AUTO_UPDATE="true"

# Pluginy
plugins=(
  git
  fzf-tab
  you-should-use
  zsh-autosuggestions
  sudo
  alias-finder
{{- if eq .chezmoi.os "darwin" }}
  yarn
{{- end }}
  zsh-syntax-highlighting # Vždy jako poslední
)

source $ZSH/oh-my-zsh.sh

# PATH
export PATH="$HOME/.cargo/bin:$HOME/.local/bin:$PATH"
export XDG_CONFIG_HOME="$HOME/.config"

{{- if eq .chezmoi.os "darwin" }}
# macOS-specific
export PNPM_HOME="$HOME/Library/pnpm"
export PATH="$PNPM_HOME:$PATH"
export PATH="$HOME/.codeium/windsurf/bin:$PATH"
export PATH="$HOME/.rd/bin:$PATH"
{{- end }}

# Aliasy
alias v="nvim"
alias tmuxa="tmux attach-session -t \$(tmux list-sessions -F '#{session_name}' | fzf)"
alias clauded="claude --dangerously-skip-permissions"
{{- if eq .chezmoi.os "darwin" }}
alias dev="cd ~/Development/Trask"
{{- end }}

# Lokální config (mimo chezmoi - např. OpenClaw, secrets, machine-specific)
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# Powerlevel10k config
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh
